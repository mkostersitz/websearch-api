{
  "title": "WebSearch API - System Overview",
  "uid": "websearch-api-overview",
  "tags": ["websearch", "api", "overview"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "type": "timeseries",
      "title": "HTTP Requests per Second",
      "targets": [
        {
          "expr": "rate(http_server_requests_total[1m])",
          "legendFormat": "{{method}} {{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "reqps"
        }
      },
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}
      }
    },
    {
      "id": 2,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "type": "timeseries",
      "title": "HTTP Response Times",
      "targets": [
        {
          "expr": "http_server_duration_milliseconds_sum / http_server_duration_milliseconds_count",
          "legendFormat": "Average Duration",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "ms"
        }
      },
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      }
    },
    {
      "id": 3,
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8},
      "type": "stat",
      "title": "Total Requests",
      "targets": [
        {
          "expr": "sum(http_server_requests_total)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 100, "color": "yellow"},
              {"value": 1000, "color": "red"}
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 4,
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8},
      "type": "stat",
      "title": "Error Rate",
      "targets": [
        {
          "expr": "sum(http_server_requests_total{status_code=~\"4..|5..\"}) / sum(http_server_requests_total) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 1, "color": "yellow"},
              {"value": 5, "color": "red"}
            ]
          },
          "unit": "percent",
          "noValue": "0"
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 5,
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8},
      "type": "stat",
      "title": "Active Requests",
      "targets": [
        {
          "expr": "http_server_active_requests",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 10, "color": "yellow"},
              {"value": 50, "color": "red"}
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 6,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "type": "timeseries",
      "title": "HTTP Status Codes",
      "targets": [
        {
          "expr": "sum by (status_code) (rate(http_server_requests_total[1m]))",
          "legendFormat": "{{status_code}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "stacking": {"mode": "normal"}
          },
          "unit": "reqps"
        }
      },
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["sum"]}
      }
    },
    {
      "id": 7,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "type": "timeseries",
      "title": "Request Rate by Endpoint",
      "targets": [
        {
          "expr": "sum by (endpoint) (rate(http_server_requests_total[1m]))",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "reqps"
        }
      },
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}
      }
    },
    {
      "id": 10,
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 24},
      "type": "table",
      "title": "Top Endpoints by Request Count",
      "targets": [
        {
          "expr": "topk(10, sum by (endpoint, method) (http_server_requests_total))",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Value"},
            "properties": [
              {"id": "displayName", "value": "Request Count"},
              {"id": "unit", "value": "short"},
              {"id": "decimals", "value": 0}
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{"desc": true, "displayName": "Request Count"}]
      }
    }
  ]
}
