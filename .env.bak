# Application
APP_NAME=websearch-api
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# Database
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=websearch_api

# Redis
REDIS_URL=redis://localhost:6379/0

# Search Providers (Add your API keys here)
GOOGLE_API_KEY=AIzaSyBrjXULfpEFRibUJ2aOjIEi6On_xf0PIaI
GOOGLE_SEARCH_ENGINE_ID=
BING_API_KEY=

# OAuth - Okta (Optional)
OKTA_DOMAIN=
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=

# OAuth - Microsoft Entra ID (Optional)
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# API Security
API_KEY_HEADER=X-API-Key
JWT_SECRET_KEY=change-this-in-production-use-secrets-manager
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# OpenTelemetry
OTEL_SERVICE_NAME=websearch-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
JAEGER_AGENT_HOST=jaeger
JAEGER_AGENT_PORT=6831

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Search Configuration
SEARCH_CACHE_TTL_SECONDS=3600
SEARCH_MAX_RESULTS=100
SEARCH_DEFAULT_RESULTS=10
SEARCH_TIMEOUT_SECONDS=10
